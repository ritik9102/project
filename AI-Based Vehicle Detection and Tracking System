import cv2
from ultralytics import YOLO

# Load YOLO model
model = YOLO("yolov8n.pt")

# Vehicle names we want to detect
vehicles = ["car", "bus", "truck", "motorcycle"]

# Read video
video = cv2.VideoCapture("traffic.mp4")

while True:

    # Read one frame from video
    ret, frame = video.read()

    # Stop if video ends
    if not ret:
        break

    # Detect and track objects
    result = model.track(frame, persist=True)

    # Get detected boxes
    detected_objects = result[0].boxes

    # Check if objects are found
    if detected_objects is not None:

        for object in detected_objects:

            # Get box coordinates
            x1, y1, x2, y2 = map(int, object.xyxy[0])

            # Get object confidence
            score = float(object.conf[0])

            # Get object class ID
            class_id = int(object.cls[0])

            # Convert ID to name
            object_name = model.names[class_id]

            # Show only vehicles
            if object_name in vehicles:

                # Get tracking ID
                if object.id is not None:
                    vehicle_id = int(object.id[0])
                else:
                    vehicle_id = 0

                # Create label text
                text = object_name + " ID:" + str(vehicle_id)

                # Draw rectangle around vehicle
                cv2.rectangle(
                    frame,
                    (x1, y1),
                    (x2, y2),
                    (0, 255, 0),
                    2
                )

                # Show text above rectangle
                cv2.putText(
                    frame,
                    text,
                    (x1, y1-10),
                    cv2.FONT_HERSHEY_SIMPLEX,
                    0.6,
                    (0,255,0),
                    2
                )

    # Display output video
    cv2.imshow("Vehicle Detection", frame)

    # Press q to stop
    if cv2.waitKey(1) == ord("q"):
        break

# Close everything
video.release()
cv2.destroyAllWindows()
